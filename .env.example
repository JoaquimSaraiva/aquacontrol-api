# ---- Servidor ----
PORT=3000

# ---- Segurança ----
# Mesma chave que está no ESP32 (X-Device-Secret)
DEVICE_SECRET=minha-chave-secreta

# ---- Email (Gmail) ----
# Usa uma "App Password" do Google, não a tua password normal
# https://myaccount.google.com/apppasswords
EMAIL_USER=o_teu_email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_DESTINO=destino@gmail.com

# ---- WhatsApp (Twilio) ----
# Criar conta em https://www.twilio.com (gratuito)
# Ativar Sandbox em: Console > Messaging > Try it out > Send a WhatsApp message
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_DESTINO=+351912345678
